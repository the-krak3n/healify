# MongoDB Atlas connection string
# Get this from: MongoDB Atlas -> Database -> Connect -> Drivers
# Replace <username>, <password>, <cluster-url> with your own
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/healify?retryWrites=true&w=majority

# Any random long string - used to sign JWT tokens
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars

# Server port
PORT=5000

# Comma-separated frontend origins allowed to call the API
CLIENT_ORIGIN=http://localhost:3000

# Keep this server-side. Never put a Gemini key in React source or REACT_APP_*.
GEMINI_API_KEY=replace_with_your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=25000
